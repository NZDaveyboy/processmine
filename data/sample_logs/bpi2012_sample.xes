<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="" openxes.version="1.0RC7"
     xmlns="http://www.xes-standard.org/">
  <extension name="Concept"       prefix="concept"   uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time"          prefix="time"      uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Organizational" prefix="org"      uri="http://www.xes-standard.org/org.xesext"/>
  <extension name="Lifecycle"     prefix="lifecycle" uri="http://www.xes-standard.org/lifecycle.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="UNKNOWN"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="UNKNOWN"/>
    <date   key="time:timestamp" value="1970-01-01T00:00:00.000+00:00"/>
  </global>
  <classifier name="Activity" keys="concept:name"/>

  <!-- ============================================================
       Happy-path cases (no credit check): OTC-001 to OTC-010
       Sequence: Create Order -> Approve Order -> Pick Items ->
                 Ship Items -> Issue Invoice -> Receive Payment -> Close Order
       ============================================================ -->

